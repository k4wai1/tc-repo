#!/bin/sh
# tc-apt: Gestor de paquetes multi-repo para Tiny Core Linux

TCE_DIR="/etc/sysconfig/tcedir/optional"
ONBOOT_LST="/etc/sysconfig/tcedir/onboot.lst"
REPOS="https://k4wai1.github.io/tc-repo http://distro.ibiblio.org/tinycorelinux"
TC_VER="$(version | awk -F. '{print $1}').x"
TC_ARCH="$(uname -m)"
LISTS_DIR="/tmp/tc-apt-lists"

# Códigos de color para mejorar la UX
C_OK="\033[1;32m"
C_INFO="\033[1;34m"
C_WARN="\033[1;33m"
C_ERR="\033[1;31m"
C_RESET="\033[0m"

# --- FUNCIÓN: BUSCAR REPO LOCALMENTE ---
# Busca en qué repositorio está el paquete leyendo los índices locales
encontrar_repo_de_paquete() {
    local PKG="$1"
    local COUNT=1
    
    for REPO in $REPOS; do
        if [ -f "$LISTS_DIR/repo${COUNT}.lst" ]; then
            # Si el paquete está en la lista de este repo, devolvemos la URL
            if grep -qx "$PKG" "$LISTS_DIR/repo${COUNT}.lst" 2>/dev/null; then
                echo "$REPO"
                return 0
            fi
        fi
        COUNT=$((COUNT + 1))
    done
    return 1
}

# --- FUNCIÓN: DESCARGA RECURSIVA ---
descargar_paquete() {
    local PKG="$1"
    
    if [ -f "$TCE_DIR/$PKG" ]; then
        echo -e "${C_WARN} [~] $PKG ya está en disco. Saltando...${C_RESET}"
        return 0
    fi

    # 1. Determinar el repositorio SIN hacer peticiones web
    local REPO_ORIGEN=$(encontrar_repo_de_paquete "$PKG")
    
    if [ -z "$REPO_ORIGEN" ]; then
        echo -e "${C_ERR} [!] ERROR: No se encontró '$PKG' en las listas locales. ¿Ejecutaste 'update'?${C_RESET}"
        exit 1
    fi

    local URL_BASE="$REPO_ORIGEN/$TC_VER/$TC_ARCH/tcz"

    echo -e "${C_INFO} [↓] Descargando $PKG desde $REPO_ORIGEN...${C_RESET}"
    
    # 2. Descargar MD5 y .DEP de forma silenciosa
    wget -q -O "$TCE_DIR/$PKG.md5.txt" "$URL_BASE/$PKG.md5.txt"
    wget -q -O "$TCE_DIR/$PKG.dep" "$URL_BASE/$PKG.dep" 2>/dev/null
    
    # 3. Descargar el paquete CON barra de progreso (sin el flag -q)
    wget -O "$TCE_DIR/$PKG" "$URL_BASE/$PKG"
    
    if [ $? -ne 0 ]; then
        echo -e "${C_ERR} [!] ERROR crítico al descargar $PKG. Abortando.${C_RESET}"
        rm -f "$TCE_DIR/$PKG"* # Limpiar basura
        exit 1
    fi

    # 4. Validar el MD5
    if [ -f "$TCE_DIR/$PKG.md5.txt" ]; then
        cd "$TCE_DIR" || exit 1
        if ! md5sum -c "$PKG.md5.txt" > /dev/null 2>&1; then
            echo -e "${C_ERR} [!] ERROR: La suma MD5 de $PKG no coincide. Archivo corrupto.${C_RESET}"
            rm -f "$TCE_DIR/$PKG"*
            exit 1
        fi
        cd - > /dev/null
    fi

    # 5. Resolver dependencias recursivamente
    if [ -f "$TCE_DIR/$PKG.dep" ]; then
        while read -r DEP_PKG; do
            DEP_PKG=$(echo "$DEP_PKG" | tr -d '\r') # Limpiar saltos de línea de Windows/Linux
            if [ -n "$DEP_PKG" ]; then
                echo -e "${C_INFO} [+] Resolviendo dependencia: $DEP_PKG${C_RESET}"
                descargar_paquete "$DEP_PKG"
            fi
        done < "$TCE_DIR/$PKG.dep"
    fi
}

# --- AYUDANTE: AUTOCOMPLETAR .tcz ---
formatear_nombre() {
    case "$1" in
        *.tcz) echo "$1" ;;
        *)     echo "$1.tcz" ;;
    esac
}

# --- ESTRUCTURA PRINCIPAL ---
ACCION="$1"
PARAMETRO="$2"

case "$ACCION" in
    update)
        echo -e "${C_INFO}Actualizando listas de repositorios...${C_RESET}"
        mkdir -p "$LISTS_DIR"
        
        COUNT=1
        for REPO in $REPOS; do
            echo " -> Descargando índice de $REPO..."
            # Descargamos directamente la info, asumiendo que el server la provee
            if wget -q -O "$LISTS_DIR/repo${COUNT}.lst" "$REPO/$TC_VER/$TC_ARCH/tcz/info.lst"; then
                echo -e "${C_OK}    OK: repo${COUNT}.lst (${REPO})${C_RESET}"
            else
                echo -e "${C_ERR}    Fallo al contactar: $REPO${C_RESET}"
            fi
            COUNT=$((COUNT + 1))
        done
        echo -e "${C_OK}¡Listas actualizadas! Usa 'search' para buscar.${C_RESET}"
        ;;
        
    search)
        if [ -z "$PARAMETRO" ]; then
            echo -e "${C_ERR}Error: Escribe un término para buscar.${C_RESET}"
            exit 1
        fi
        if [ ! -d "$LISTS_DIR" ] || [ -z "$(ls -A $LISTS_DIR)" ]; then
            echo -e "${C_WARN}Las listas no existen o están vacías. Ejecuta '$0 update' primero.${C_RESET}"
            exit 1
        fi
        
        echo -e "${C_INFO}Resultados para '$PARAMETRO':${C_RESET}"
        echo "--------------------------------"
        # Muestra solo el nombre del paquete quitando el prefijo del archivo
        grep -ih "$PARAMETRO" "$LISTS_DIR"/*.lst | sort | uniq
        echo "--------------------------------"
        ;;

    install)
        if [ -z "$PARAMETRO" ]; then
            echo -e "${C_ERR}Error: Debes especificar un paquete.${C_RESET}"
            exit 1
        fi
        
        # Obliga a tener las listas para no buscar a ciegas en internet
        if [ ! -d "$LISTS_DIR" ]; then
            echo -e "${C_WARN}Advertencia: Índices no encontrados. Ejecutando 'update' automáticamente...${C_RESET}"
            $0 update
        fi

        PKG_FINAL=$(formatear_nombre "$PARAMETRO")
        echo -e "${C_INFO}--- Preparando instalación de: $PKG_FINAL ---${C_RESET}"
        descargar_paquete "$PKG_FINAL"
        
        grep -q "^$PKG_FINAL\$" "$ONBOOT_LST" || echo "$PKG_FINAL" >> "$ONBOOT_LST"
        
        echo -e "${C_INFO}--- Cargando en memoria RAM ---${C_RESET}"
        tce-load -i "$PKG_FINAL"
        echo -e "${C_OK}¡Instalación completada!${C_RESET}"
        ;;

    remove)
        if [ -z "$PARAMETRO" ]; then
            echo -e "${C_ERR}Error: Especifica el paquete a eliminar.${C_RESET}"
            exit 1
        fi
        
        PKG_FINAL=$(formatear_nombre "$PARAMETRO")
        echo -e "${C_WARN}Eliminando $PKG_FINAL del disco...${C_RESET}"
        
        rm -f "$TCE_DIR/$PKG_FINAL"*
        sed -i "/^$PKG_FINAL\$/d" "$ONBOOT_LST"
        
        echo -e "${C_OK}¡Eliminado del almacenamiento local!${C_RESET}"
        echo -e "${C_WARN}[!] NOTA: El programa sigue en la RAM. Reinicia para liberarlo completamente.${C_RESET}"
        ;;

    upgrade)
        # Puedes aplicar una lógica similar a la de 'install' aquí, 
        # buscando primero la URL base desde las listas actualizadas.
        echo -e "${C_WARN}Función upgrade pendiente de optimizar con la nueva lógica local.${C_RESET}"
        ;;

    *)
        echo "tc-apt - Gestor Multi-Repo para Tiny Core"
        echo "Uso: $0 {update|search|install|remove|upgrade} [paquete]"
        ;;
esac
